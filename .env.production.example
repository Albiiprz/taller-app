# ==========================================================
# taller-app — Plantilla de variables para producción
# ==========================================================
# Copia a `.env` en el servidor antes de levantar el compose:
#   cp .env.production.example .env
# y rellena los valores. NO commitees el .env real.

# ---- Base de datos ----
DB_USER=taller
# Genera una contraseña fuerte (no la de dev). Ejemplo:
#   openssl rand -base64 24 | tr -d '=+/' | cut -c1-28
DB_PASSWORD=CAMBIAME_pon_aqui_una_password_fuerte
DB_NAME=taller
DB_POOL_MAX=10

# ---- JWT (regenera ambos para producción) ----
# Generar:  openssl rand -hex 32
JWT_SECRET=CAMBIAME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CAMBIAME_openssl_rand_hex_32
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# ---- Google Calendar (opcional) ----
# Si no usas integración con Google Calendar, déjalo vacío y la app sigue funcionando.
# El fichero del Service Account se monta en ./apps/api/keys/google-service-account.json
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_TIMEZONE=Europe/Madrid
# Usuario técnico "genérico" para importaciones desde Google Calendar.
# Si existe login_name=tecnico, se usará ese. Si no, se usa el primer técnico activo.
GOOGLE_IMPORT_TECHNICIAN_LOGIN=tecnico
# Sincronización automática Google Calendar -> App
GOOGLE_CALENDAR_IMPORT_AUTO_ENABLED=true
GOOGLE_CALENDAR_IMPORT_LOOKBACK_HOURS=24
GOOGLE_CALENDAR_IMPORT_LOOKAHEAD_DAYS=90

# ---- WhatsApp (opcional) ----
# Si no envías mensajes por WhatsApp, déjalo vacío.
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_TOKEN=
WHATSAPP_PROVIDER_TIMEOUT_MS=15000

# ---- Notificaciones ----
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_MS=60000

# ---- CORS (frontend permitido en producción) ----
# Lista separada por comas. Ejemplo:
# CORS_ALLOWED_ORIGINS=https://taller-app.duckdns.org,https://otro-dominio.com
CORS_ALLOWED_ORIGINS=https://taller-app.duckdns.org

# ---- Web Push (PWA Android/iPhone) ----
# Genera claves VAPID en tu Mac/servidor con:
#   cd apps/api && npx web-push generate-vapid-keys --json
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Email de contacto técnico
WEB_PUSH_VAPID_SUBJECT=mailto:admin@taller-app.local
